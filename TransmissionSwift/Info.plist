<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Transmission daemons commonly serve plain HTTP on the LAN; users
	     enter arbitrary hosts, so a blanket ATS exception is required
	     (same model as transgui). HTTPS profiles still use TLS. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<!-- Handle double-clicked / "Open With" .torrent files. The UTI
	     org.bittorrent.torrent isn't system-declared, so we import it.
	     LSHandlerRank "Alternate" claims handling without grabbing the
	     system-default away from a full BitTorrent client. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>BitTorrent Document</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>org.bittorrent.torrent</string>
			</array>
		</dict>
	</array>
	<key>UTImportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>org.bittorrent.torrent</string>
			<key>UTTypeDescription</key>
			<string>BitTorrent Document</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>torrent</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/x-bittorrent</string>
				</array>
			</dict>
		</dict>
	</array>
	<!-- Sparkle auto-update settings -->
	<key>SUFeedURL</key>
	<string>https://jvacek.github.io/TransmissionSwift/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>yOx9DTZyOyDSed94L5kAT1cXbakXVwJGcCLXZEr/uQg=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<!-- Handle magnet: links opened from a browser. Routed through the same
	     .onOpenURL handler as .torrent files. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Magnet Link</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>magnet</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
